{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "ADF-SalesProject-Aakash"
		},
		"LS_ABLB_SRC_Sales_DataEnginnering_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'LS_ABLB_SRC_Sales_DataEnginnering'"
		},
		"LS_SINK_Sales_DataEnginnering_ADLS_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_SINK_Sales_DataEnginnering_ADLS'"
		},
		"LS_SSERVER_OnPREM_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_SSERVER_OnPREM'"
		},
		"LS_AKV_Sales_DataEnginnering_Project_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://KV-SalesProject-Akash.vault.azure.net/"
		},
		"LS_AzureSQL_LogPipelineStart_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "asqlserver-salesproject-akash.database.windows.net"
		},
		"LS_AzureSQL_LogPipelineStart_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "ASQL_SalesProject_Akash"
		},
		"LS_AzureSQL_LogPipelineStart_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "user"
		},
		"LS_SINK_Sales_DataEnginnering_ADLS_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlssalesprojectakash.dfs.core.windows.net/"
		},
		"LS_SSERVER_OnPREM_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "localhost\\SQLEXPRESS"
		},
		"LS_SSERVER_OnPREM_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "SALES"
		},
		"LS_SSERVER_OnPREM_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "DESKTOP-CHLIQ1G\\Admin"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "ADF-SalesProject-Aakash_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_ABLB_SRC_Sales_DataEnginnering_connectionString": {
						"value": "[parameters('LS_ABLB_SRC_Sales_DataEnginnering_connectionString')]"
					},
					"LS_SINK_Sales_DataEnginnering_ADLS_accountKey": {
						"value": "[parameters('LS_SINK_Sales_DataEnginnering_ADLS_accountKey')]"
					},
					"LS_SSERVER_OnPREM_password": {
						"value": "[parameters('LS_SSERVER_OnPREM_password')]"
					},
					"LS_AKV_Sales_DataEnginnering_Project_properties_typeProperties_baseUrl": {
						"value": "[parameters('LS_AKV_Sales_DataEnginnering_Project_properties_typeProperties_baseUrl')]"
					},
					"LS_SINK_Sales_DataEnginnering_ADLS_properties_typeProperties_url": {
						"value": "[parameters('LS_SINK_Sales_DataEnginnering_ADLS_properties_typeProperties_url')]"
					},
					"LS_AzureSQL_LogPipelineStart_properties_typeProperties_server": {
						"value": "[parameters('LS_AzureSQL_LogPipelineStart_properties_typeProperties_server')]"
					},
					"LS_AzureSQL_LogPipelineStart_properties_typeProperties_database": {
						"value": "[parameters('LS_AzureSQL_LogPipelineStart_properties_typeProperties_database')]"
					},
					"LS_AzureSQL_LogPipelineStart_properties_typeProperties_userName": {
						"value": "[parameters('LS_AzureSQL_LogPipelineStart_properties_typeProperties_userName')]"
					},
					"LS_SSERVER_OnPREM_properties_typeProperties_server": {
						"value": "[parameters('LS_SSERVER_OnPREM_properties_typeProperties_server')]"
					},
					"LS_SSERVER_OnPREM_properties_typeProperties_database": {
						"value": "[parameters('LS_SSERVER_OnPREM_properties_typeProperties_database')]"
					},
					"LS_SSERVER_OnPREM_properties_typeProperties_userName": {
						"value": "[parameters('LS_SSERVER_OnPREM_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}